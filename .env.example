TELEGRAM_BOT_TOKEN=your_bot_token_here
AUTHORIZED_USER_IDS=123456789,987654321,555555555
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Web dashboard
DASHBOARD_PASSWORD=changeme
DASHBOARD_PORT=5000

# Sync from Android bot → VPS dashboard (add these to Android .env only)
DASHBOARD_URL=https://dashboard.sovan.info
DASHBOARD_SYNC_TOKEN=generate_a_random_secret_here

# Local Telegram Bot API server — unlocks 2 GB uploads (optional)
# Get API_ID and API_HASH from https://my.telegram.org → API Development
# Then run: pkg install telegram-bot-api
LOCAL_BOT_API=false
API_ID=
API_HASH=
LOCAL_BOT_API_PORT=8081
